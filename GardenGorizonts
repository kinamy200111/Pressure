                        AdvSwitchMannyEnable.Ind.Position = AdvSwitchMannyEnable.Bg.Position + Vector2.new(1, 1)
                    end
                end
            end

            if VeryBackGUI.Visible and mPos.X >= VeryBackGUI.Position.X and mPos.X <= VeryBackGUI.Position.X + VeryBackGUI.Size.X and
               mPos.Y >= VeryBackGUI.Position.Y and mPos.Y <= VeryBackGUI.Position.Y + VeryBackGUI.Size.Y then
                dragging = true
                dragStart = mPos
                startPos = VeryBackGUI.Position
            end

            if MainWatermark.Visible and mPos.X >= MainWatermark.Position.X and mPos.X <= MainWatermark.Position.X + MainWatermark.Size.X and
               mPos.Y >= MainWatermark.Position.Y and mPos.Y <= MainWatermark.Position.Y + MainWatermark.Size.Y then
                watermarkDragging = true
                watermarkDragStart = mPos
                watermarkStartPos = MainWatermark.Position
            end

            if advancedWindowOpen then
                if _G.adv_manny then
                    local a = _G.adv_manny
                    if a.swEnable and a.swEnable.Bg and a.swEnable.Bg.Visible and mPos.X >= a.swEnable.Bg.Position.X and mPos.X <= a.swEnable.Bg.Position.X + a.swEnable.Bg.Size.X and
                       mPos.Y >= a.swEnable.Bg.Position.Y and mPos.Y <= a.swEnable.Bg.Position.Y + a.swEnable.Bg.Size.Y then
                        a.swEnable.IsChecked = not a.swEnable.IsChecked
                        UpdateSwitchColor(a.swEnable.Bg, a.swEnable.IsChecked)
                        if a.swEnable.IsChecked then
                            a.swEnable.IndBorder.Position = a.swEnable.Bg.Position + Vector2.new(16, 1)
                            a.swEnable.Ind.Position = a.swEnable.Bg.Position + Vector2.new(16, 1)
                        else
                            a.swEnable.IndBorder.Position = a.swEnable.Bg.Position + Vector2.new(1, 1)
                            a.swEnable.Ind.Position = a.swEnable.Bg.Position + Vector2.new(1, 1)
                        end
                        mannyEnabled = a.swEnable.IsChecked
                        MainSwitchManny.IsChecked = mannyEnabled
                        UpdateSwitchColor(SwitchManny_Bg, mannyEnabled)
                        if mannyEnabled then
                            SwitchManny_IndBorder.Position = SwitchManny.Position + Vector2.new(11, 1)
                            SwitchManny_Ind.Position = SwitchManny.Position + Vector2.new(11, 1)
                        else
                            SwitchManny_IndBorder.Position = SwitchManny.Position + Vector2.new(1, 1)
                            SwitchManny_Ind.Position = SwitchManny.Position + Vector2.new(1, 1)
                        end
                    end
                    if a.speedSlider and a.speedSlider.track and a.speedSlider.track.Visible and mPos.X >= a.speedSlider.track.Position.X and mPos.X <= a.speedSlider.track.Position.X + a.speedSlider.track.Size.X and
                       mPos.Y >= a.speedSlider.track.Position.Y-10 and mPos.Y <= a.speedSlider.track.Position.Y+10 then
                        a.speedSlider.dragging = true
                        local relX = mPos.X - a.speedSlider.track.Position.X
                        local newVal = 0.1 + (relX / a.speedSlider.track.Size.X) * (10-0.1)
                        newVal = math.max(0.1, math.min(10, newVal))
                        mannySpeed = newVal
                        a.speedSlider.text.Text = string.format("%.1f", newVal) .. "s"
                        a.speedSlider.fill.Size = Vector2.new(a.speedSlider.track.Size.X * ((newVal-0.1)/(10-0.1)), a.speedSlider.fill.Size.Y)
                        a.speedSlider.knob.Position = a.speedSlider.track.Position + Vector2.new(a.speedSlider.track.Size.X * ((newVal-0.1)/(10-0.1)), 2)
                    end
                end
            end
        end

        if mouse2 and not lastMouse2 then
            if ContentExploits1.Visible and mPos.X >= ContentExploits1.Position.X and mPos.X <= ContentExploits1.Position.X + ContentExploits1.Size.X and
               mPos.Y >= ContentExploits1.Position.Y and mPos.Y <= ContentExploits1.Position.Y + ContentExploits1.Size.Y then
