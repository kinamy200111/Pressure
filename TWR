local function ApplyHeadExtender()
    if not HeadExtenderEnabled then
        for head, origSize in pairs(OriginalHeadSizes) do
            if head and head.Parent then
                head.Size = origSize
            end
        end
        OriginalHeadSizes = {}
        return
    end
    local folder = workspace:FindFirstChild("Entities")
    if folder then
        folder = folder:FindFirstChild("Infected")
    end
    if not folder then return end
    for _, npc in ipairs(folder:GetChildren()) do
        local head = npc:FindFirstChild("Head")
        if head and head:IsA("BasePart") then
            if not OriginalHeadSizes[head] then
                OriginalHeadSizes[head] = head.Size
            end
            head.Size = Vector3.new(HeadExtenderSize, HeadExtenderSize, HeadExtenderSize)
        end
    end
    for head, _ in pairs(OriginalHeadSizes) do
        if not head or not head.Parent then
            OriginalHeadSizes[head] = nil
        end
    end
end

