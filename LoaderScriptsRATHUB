-- Функция полной выгрузки лоадера (удаление всех объектов и остановка)
local function unloadLoader()
    if unloaded then return end
    unloaded = true
    -- Удаляем все Drawing объекты
    for _, obj in ipairs(allDrawings) do
        pcall(function() obj:Remove() end)
    end
    -- Разблокируем мышь
    setrobloxinput(true)
    -- Останавливаем выполнение (выйдем из цикла в main)
end

-- Функция выполнения скрипта и последующей выгрузки
local function executeAndUnload(url)
    -- Выполняем скрипт
    local success, err = pcall(function()
        loadstring(game:HttpGet(url))()
    end)
    if not success then
        warn("Script execution failed: " .. tostring(err))
    end
    -- Ждём 3 секунды
    wait(3)
    -- Выгружаем лоадер
    unloadLoader()
end

-- Основная функция с циклом обработки
local function main()
    local dragging = nil
    local dragStart = nil
    local startPos = nil
    local lastMouse1 = false
    local guiVisible = true -- текущее состояние видимости GUI

    while not unloaded do
        wait(0.01)
        if isrbxactive() then
            local mouse1 = ismouse1pressed()
            local mPos = Vector2.new(Mouse.X, Mouse.Y)

            -- Обработка нажатия F1 для открытия/закрытия GUI
            if iskeypressed(closeKey) then
                guiVisible = not guiVisible
                -- Устанавливаем видимость всех основных элементов GUI
                VeryBackGUI.Visible = guiVisible
                VeryBackGUI_Border.Visible = guiVisible
                Line1.Visible = guiVisible
                BackGUItabs.Visible = guiVisible
                Line3.Visible = guiVisible
                Line2.Visible = guiVisible
                TextRATHUB.Visible = guiVisible
                TextLOGO.Visible = guiVisible
                BackContentTabs.Visible = guiVisible
                BackContentTabs_Border.Visible = guiVisible
                BackGUI2.Visible = guiVisible
                BackGUI2_Border.Visible = guiVisible
                TabHUB.Visible = guiVisible
                TabHUB_Text.Visible = guiVisible
                TabHUB_Border.Visible = guiVisible and activeTab -- показывать бордер только если активна вкладка
                Line.Visible = guiVisible
                -- Контент вкладки показываем только если GUI видим и активна вкладка
                if guiVisible then
                    SetScriptHUBContentVisible(activeTab)
                else
                    -- Скрываем контент вкладки при скрытии GUI
                    GameBack1.Visible = false
                    GameBack1_Border.Visible = false
                    SupportGameText.Visible = false
                    NumberGameInList.Visible = false
                    PressureText.Visible = false
                    Status1.Visible = false
                    Status1_Border.Visible = false
                    WorkingStatus.Visible = false
                    Execute1.Visible = false
                    Execute1_Text.Visible = false
                    Execute1_Border.Visible = false
                    GameBack2.Visible = false
                    GameBack2_Border.Visible = false
                    GardenHorizontsText.Visible = false
                    NumberGameInList1.Visible = false
                    Status2.Visible = false
                    Status2_Border.Visible = false
                    DevelopStatus.Visible = false
                    Execute2.Visible = false
                    Execute2_Text.Visible = false
                    Execute2_Border.Visible = false
                end
                -- Блокируем/разблокируем мышь
                setrobloxinput(not guiVisible)
                wait(0.2)
            end

            -- Подсветка при наведении на TabHUB (только если GUI видим)
            if TabHUB.Visible and guiVisible then
                local hover = mPos.X >= TabHUB.Position.X and mPos.X <= TabHUB.Position.X + TabHUB.Size.X and
                              mPos.Y >= TabHUB.Position.Y and mPos.Y <= TabHUB.Position.Y + TabHUB.Size.Y
                if hover then
                    TabHUB.Color = Color3.fromHex("#1a1a1a")
                    if not activeTab then
                        -- Если вкладка не активна, показываем временную подсветку бордера
                        TabHUB_Border.Color = Color3.fromHex("#00c950")
                        TabHUB_Border.Visible = true
                    end
                else
                    if not activeTab then
                        TabHUB.Color = Color3.fromHex("#0c0c0d")
                        TabHUB_Border.Visible = false
                    else
                        -- Если активна, цвет уже установлен в SetScriptHUBContentVisible
                    end
                end
            end

            -- Подсветка бордеров для блоков GameBack1, GameBack2, Execute1, Execute2, Status1, Status2
            local blocksWithBorder = {
                {block = GameBack1, border = GameBack1_Border},
                {block = GameBack2, border = GameBack2_Border},
                {block = Execute1, border = Execute1_Border},
                {block = Execute2, border = Execute2_Border},
                {block = Status1, border = Status1_Border},
                {block = Status2, border = Status2_Border},
            }
            for _, item in ipairs(blocksWithBorder) do
                if item.block.Visible and guiVisible then
                    local hover = mPos.X >= item.block.Position.X and mPos.X <= item.block.Position.X + item.block.Size.X and
                                  mPos.Y >= item.block.Position.Y and mPos.Y <= item.block.Position.Y + item.block.Size.Y
                    if hover then
                        item.border.Color = Color3.fromHex("#00c950")
                    else
                        -- Возвращаем исходный цвет (в зависимости от элемента)
                        if item.block == GameBack1 or item.block == GameBack2 then
                            item.border.Color = Color3.fromHex("#000000")
                        elseif item.block == Execute1 or item.block == Execute2 then
                            item.border.Color = Color3.fromHex("#285439")
                        elseif item.block == Status1 or item.block == Status2 then
                            item.border.Color = Color3.fromHex("#1c4b2d")
                        end
                    end
                end
            end

            -- Mouse Down (Just Pressed)
            if mouse1 and not lastMouse1 then
                -- Button TabHUB
                if TabHUB.Visible and mPos.X >= TabHUB.Position.X and mPos.X <= TabHUB.Position.X + TabHUB.Size.X and
                   mPos.Y >= TabHUB.Position.Y and mPos.Y <= TabHUB.Position.Y + TabHUB.Size.Y then
                    -- Переключаем видимость контента
                    SetScriptHUBContentVisible(not activeTab)
                end

                -- Button Execute1
                if Execute1.Visible and mPos.X >= Execute1.Position.X and mPos.X <= Execute1.Position.X + Execute1.Size.X and
                   mPos.Y >= Execute1.Position.Y and mPos.Y <= Execute1.Position.Y + Execute1.Size.Y then
                    -- Запускаем выполнение скрипта Pressure и выгрузку в отдельном потоке, чтобы не блокировать цикл
                    spawn(function()
                        executeAndUnload("https://raw.githubusercontent.com/kinamy200111/Pressure/refs/heads/main/Pressure.lua")
                    end)
                end

                -- Button Execute2
                if Execute2.Visible and mPos.X >= Execute2.Position.X and mPos.X <= Execute2.Position.X + Execute2.Size.X and
                   mPos.Y >= Execute2.Position.Y and mPos.Y <= Execute2.Position.Y + Execute2.Size.Y then
                    spawn(function()
                        executeAndUnload("https://raw.githubusercontent.com/kinamy200111/Pressure/refs/heads/main/GardenGorizonts")
                    end)
                end

                -- Drag VeryBackGUI (только если клик по верхней панели)
                if VeryBackGUI.Visible and mPos.X >= VeryBackGUI.Position.X and mPos.X <= VeryBackGUI.Position.X + VeryBackGUI.Size.X and
                   mPos.Y >= VeryBackGUI.Position.Y and mPos.Y <= VeryBackGUI.Position.Y + VeryBackGUI.Size.Y then
                    dragging = VeryBackGUI
                    dragStart = mPos
                    startPos = VeryBackGUI.Position
                end
            end

            -- Mouse Up (Just Released)
            if not mouse1 and lastMouse1 then
                dragging = nil
            end

            -- Dragging Update
            if dragging and mouse1 then
                local delta = mPos - dragStart
                dragging.Position = startPos + delta
                if dragging == VeryBackGUI then
                    VeryBackGUI_Border.Position = dragging.Position
                    Line1.Position = dragging.Position + Vector2.new(0, 41.5)
                    BackGUItabs.Position = dragging.Position + Vector2.new(0, 42)
                    Line3.Position = dragging.Position + Vector2.new(-2.5, 84)
                    Line2.Position = dragging.Position + Vector2.new(0, 42)
                    TextRATHUB.Position = dragging.Position + Vector2.new(48, 13)
                    TextLOGO.Position = dragging.Position + Vector2.new(20, 13)
                    BackContentTabs.Position = dragging.Position + Vector2.new(0, 84)
                    BackContentTabs_Border.Position = BackContentTabs.Position
                    BackGUI2.Position = dragging.Position + Vector2.new(0, 488)
                    BackGUI2_Border.Position = BackGUI2.Position
                    TabHUB.Position = dragging.Position + Vector2.new(122, 51.5)
                    TabHUB_Border.Position = TabHUB.Position
                    TabHUB_Text.Position = TabHUB.Position + Vector2.new(300/2, 22/2)
                    Line.Position = dragging.Position + Vector2.new(567, 41.5)
                    GameBack1.Position = dragging.Position + Vector2.new(25.5, 130)
                    GameBack1_Border.Position = GameBack1.Position
                    SupportGameText.Position = dragging.Position + Vector2.new(31, 100)
                    NumberGameInList.Position = dragging.Position + Vector2.new(39, 141)
                    PressureText.Position = dragging.Position + Vector2.new(65, 141)
                    Status1.Position = dragging.Position + Vector2.new(386, 141)
                    Status1_Border.Position = Status1.Position
                    WorkingStatus.Position = dragging.Position + Vector2.new(400, 144.5)
                    Execute1.Position = dragging.Position + Vector2.new(456, 141)
                    Execute1_Border.Position = Execute1.Position
                    Execute1_Text.Position = Execute1.Position + Vector2.new(57/2, 16/2)
                    GameBack2.Position = dragging.Position + Vector2.new(25.5, 175)
                    GameBack2_Border.Position = GameBack2.Position
                    GardenHorizontsText.Position = dragging.Position + Vector2.new(65, 187)
                    NumberGameInList1.Position = dragging.Position + Vector2.new(39, 187)
                    Status2.Position = dragging.Position + Vector2.new(347, 187)
                    Status2_Border.Position = Status2.Position
                    DevelopStatus.Position = dragging.Position + Vector2.new(366, 189.5)
                    Execute2.Position = dragging.Position + Vector2.new(456, 187)
                    Execute2_Border.Position = Execute2.Position
                    Execute2_Text.Position = Execute2.Position + Vector2.new(57/2, 16/2)
                end
            end

            lastMouse1 = mouse1
        end
    end
end

-- Запускаем основной цикл
main()
