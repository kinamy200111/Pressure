-- Таблица для хранения всех созданных Drawing объектов (для полной очистки)
local allDrawings = {}

-- Функция добавления объекта в список и возврат его
local function newDrawing(drawType, ...)
    local obj = Drawing.new(drawType)
    -- устанавливаем свойства, переданные в ...
    -- (для простоты будем добавлять вручную после создания)
    table.insert(allDrawings, obj)
    return obj
end

-- Создание GUI элементов с автоматическим добавлением в allDrawings
-- (переопределим стандартное создание, чтобы не менять весь код, 
-- но проще будет после создания каждого объекта вручную добавлять в таблицу.
-- Вместо этого в конце скрипта перед выгрузкой пройдём по всем известным переменным и удалим их.
-- Но чтобы гарантированно удалить всё, добавим каждый объект в таблицу при создании.

-- Для удобства напишем функцию, которая создаёт объект и сразу добавляет
local function createDrawing(drawType, props)
    local obj = Drawing.new(drawType)
    for k, v in pairs(props) do
        obj[k] = v
    end
    table.insert(allDrawings, obj)
    return obj
end

